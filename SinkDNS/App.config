                <value>config/blocklist.ini</value>
            </setting>
            <setting name="WhitelistIniLocation" serializeAs="String">
                <value>config/whitelist.ini</value>
            </setting>
            <setting name="UserBlocklistIniLocation" serializeAs="String">
                <value>config/userblocklist.txt</value>
            </setting>
            <setting name="UserWhitelistIniLocation" serializeAs="String">
                <value>config/userwhitelist.txt</value>
            </setting>
            <setting name="CombinedBlocklistFileLocation" serializeAs="String">
                <value>hostfiles/blocklist/combined-blocklist.txt</value>
            </setting>
            <setting name="CombinedWhitelistFileLocation" serializeAs="String">
                <value>hostfiles/whitelist/combined-whitelist.txt</value>
            </setting>
            <setting name="LogsFolderLocation" serializeAs="String">
                <value>logs</value>
            </setting>
