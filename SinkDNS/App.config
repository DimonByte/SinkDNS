                <value>config</value>
            </setting>
            <setting name="ResolversFolderLocation" serializeAs="String">
                <value>resolvers</value>
            </setting>
            <setting name="HostFilesFolderLocation" serializeAs="String">
                <value>hostfiles</value>
            </setting>
            <setting name="BackupFolderLocation" serializeAs="String">
                <value>backup</value>
            </setting>
            <setting name="TaskSchedulerIniLocation" serializeAs="String">
                <value>taskschedules/taskscheduler.ini</value>
            </setting>
            <setting name="TaskScheduleFolderLocation" serializeAs="String">
                <value>taskschedules</value>
            </setting>
        </SinkDNS.Properties.Settings>
    </applicationSettings>
    <userSettings>
        <SinkDNS.Properties.Settings>
            <setting name="EnableDiskLogging" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="LogExpiryInDays" serializeAs="String">
                <value>30</value>
            </setting>
            <setting name="PendingDNSCryptRestart" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="DNSCryptInstallationLocation" serializeAs="String">
                <value>C:\Program Files\dnscrypt-proxy</value>
            </setting>
            <setting name="TraceLoggerThreshold" serializeAs="String">
                <value>Information</value>
            </setting>
            <setting name="DisableDNSCryptRestartWarning" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="RestartDNSCryptAfterUpdatingLists" serializeAs="String">
                <value>True</value>
            </setting>
        </SinkDNS.Properties.Settings>
    </userSettings>
</configuration>